01:48:43.103483 [debug]: Query executed on node unknown:
select * from (
with customers as (

    -- use ref macro to reference the staging model for customers
    select * from analytics.dbt_eelikem.stg_jaffle_shop_customers

),

orders as (

    -- use ref macro to reference the staging model for orders
    select * from analytics.dbt_eelikem.stg_jaffle_shop_orders

),

payment as (

    -- use ref macro to reference the staging model for payment
    select * from analytics.dbt_eelikem.stg_stripe_payment

),

customer_orders as (

    select
        customer_id,

        min(order_date) as first_order_date,
        max(order_date) as most_recent_order_date,
        count(order_id) as number_of_orders

    from orders

    group by 1

),


final as (

    select
        customers.customer_id,
        customers.first_name,
        customers.last_name,
        customer_orders.first_order_date,
        customer_orders.most_recent_order_date,
        coalesce(customer_orders.number_of_orders, 0) as number_of_orders,
        -- payment.amount as lifetime_value
        payment.amount as lifetime_value

    from customers

    left join customer_orders using (customer_id)
    left join payment 
        on payment.order_id = orders.order_id

)
SELECT * FROM FINAL
) limit 1000
